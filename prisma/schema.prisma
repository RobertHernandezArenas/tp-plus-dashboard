generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

model User {
  user_id        String     @id @default(uuid()) @db.Char(100)
  email          String     @unique @db.VarChar(50)
  password       String     @db.VarChar(255)
  role           Role       @default(USER)
  account_status UserStatus @default(ACTIVATED)
  refresh_token  String?    @db.Text
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt

  @@map("users")
}

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVATED
  DEACTIVATED
}
